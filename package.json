{
  "name": "fast-vite-nestjs-electron",
  "version": "0.0.1",
  "packageManager": "pnpm@11.5.0",
  "description": "Vite + Electron with Doubleshot, so fast! ⚡",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "rimraf dist && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npx simple-git-hooks && electron-builder install-app-deps"
  },
  "dependencies": {
    "@doubleshot/nest-electron": "^0.2.14",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/microservices": "^11.1.24",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "^1.0.155",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/compiler-sfc": "3.5.35",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "eslint": "10.4.1",
    "lint-staged": "17.0.7",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-doubleshot": "0.0.23",
    "vue-tsc": "3.3.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}

{
  "name": "fast-vite-nestjs-electron",
  "version": "0.0.1",
  "packageManager": "pnpm@10.32.1",
  "description": "Vite + Electron with Doubleshot, so fast! ⚡",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "rimraf dist && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npx simple-git-hooks && electron-builder install-app-deps"
  },
  "dependencies": {
    "@doubleshot/nest-electron": "^0.2.11",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/microservices": "^11.1.14",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "^1.0.147",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/compiler-sfc": "3.5.30",
    "electron": "41.0.2",
    "electron-builder": "26.8.1",
    "eslint": "10.0.3",
    "lint-staged": "16.4.0",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vite-plugin-doubleshot": "0.0.21",
    "vue-tsc": "3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "electron",
      "electron-winstaller",
      "esbuild",
      "simple-git-hooks"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
